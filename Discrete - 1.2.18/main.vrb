\frametitle{Python code(for plotting x[n] obtained from difference equation)}
    \begin{lstlisting}[language=Python]
    plt.setp(stemlines, linewidth=1.5)
plt.title(" x[n] vs n (through difference equation", fontsize=13, fontweight='bold')
plt.xlabel("n", fontsize=11)
plt.ylabel("x[n]", fontsize=11)
plt.grid(True, alpha=0.3)
plt.xlim(-10, 10)
plt.ylim(min(x) - 0.1, 0.1)
plt.tight_layout()
plt.show()
